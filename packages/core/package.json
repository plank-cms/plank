{
  "name": "@plank/core",
  "version": "0.2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./server": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "node --env-file=../../.env --import tsx/esm --watch src/index.ts",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.995.0",
    "@aws-sdk/s3-request-presigner": "3.995.0",
    "@plank/db": "workspace:*",
    "@plank/schema": "workspace:*",
    "bcryptjs": "3.0.3",
    "cors": "2.8.6",
    "express": "5.2.1",
    "helmet": "8.1.0",
    "jsonwebtoken": "9.0.3",
    "multer": "2.1.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "3.0.0",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/jsonwebtoken": "9.0.10",
    "@types/multer": "2.1.0"
  }
}
