{
  "name": "@plank-cms/plank",
  "version": "0.31.3",
  "description": "Self-hosted headless CMS. Deploy in minutes on your own infrastructure.",
  "type": "module",
  "files": [
    "dist"
  ],
  "bin": {
    "plank": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/"
  },
  "author": {
    "name": "Alejandro Mártir",
    "url": "https://alemartir.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/plank-cms/plank#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/plank-cms/plank.git"
  },
  "bugs": {
    "url": "https://github.com/plank-cms/plank/issues"
  },
  "keywords": [
    "cms",
    "headless-cms",
    "self-hosted",
    "express",
    "postgresql",
    "nodejs",
    "typescript",
    "am25"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1034.0",
    "@aws-sdk/s3-request-presigner": "3.1034.0",
    "@clack/prompts": "0.9.1",
    "bcryptjs": "3.0.3",
    "chalk": "5.6.2",
    "cors": "2.8.6",
    "dotenv": "16.6.1",
    "execa": "9.6.1",
    "express": "5.2.1",
    "fs-extra": "11.3.4",
    "handlebars": "4.7.9",
    "helmet": "8.1.0",
    "jsonwebtoken": "9.0.3",
    "multer": "2.1.1",
    "nodemailer": "8.0.10",
    "pg": "8.20.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@plank-cms/core": "workspace:*",
    "@plank-cms/db": "workspace:*",
    "@plank-cms/schema": "workspace:*",
    "@types/fs-extra": "11.0.4",
    "@types/pg": "8.20.0",
    "tsup": "8.5.1"
  }
